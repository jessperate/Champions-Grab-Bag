{
  "functions": {
    "api/headshot.js": {
      "memory": 1024,
      "maxDuration": 45
    },
    "api/dataviz.js": {
      "memory": 1024,
      "maxDuration": 45
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
